{
  "server": {
    "port": 5000,
    "host": "localhost"
  },
  "security": {
    "apiSecret": ""
  },
  "database": {
    "default": "mongodb",
    "mongodb": {
      "uri": "mongodb://localhost:27017/portfolio",
      "options": {
        "maxPoolSize": 10,
        "serverSelectionTimeoutMS": 5000,
        "socketTimeoutMS": 45000
      }
    },
    "postgresql": {
      "host": "localhost",
      "port": 5432,
      "database": "base_server",
      "username": "",
      "password": "",
      "ssl": false,
      "maxConnections": 10
    }
  },
  "ai": {
    "defaultProvider": "gemini",
    "providers": {
      "gemini": {
        "apiKey": "",
        "model": "gemini-1.5-pro",
        "models": ["gemini-1.5-pro", "gemini-1.5-flash", "gemini-1.0-pro", "gemini-pro"],
        "maxTokens": 1000,
        "temperature": 0.7
      },
      "openai": {
        "apiKey": "",
        "model": "gpt-4o-mini",
        "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo", "gpt-3.5-turbo", "dall-e-3", "text-embedding-ada-002"],
        "maxTokens": 1000,
        "temperature": 0.7
      },
      "grok": {
        "apiKey": "",
        "model": "grok-2-1212",
        "models": ["grok-2-1212", "grok-beta", "grok-2-vision-1212"],
        "maxTokens": 1000,
        "temperature": 0.7
      },
      "anthropic": {
        "apiKey": "",
        "model": "claude-3-sonnet-20240229",
        "models": ["claude-3-opus-20240229", "claude-3-sonnet-20240229", "claude-3-haiku-20240307"],
        "maxTokens": 1000,
        "temperature": 0.7
      }
    }
  },
  "projects": {
    "portfolio": {
      "database": "mongodb",
      "enabled": true,
      "routes": ["projects", "designs", "badges", "categories", "blogposts", "files"]
    }
  },
  "upload": {
    "maxFileSize": 20000000,
    "allowedTypes": ["image/jpeg", "image/jpg", "image/png", "image/gif"],
    "bucketName": "uploads"
  }
}
