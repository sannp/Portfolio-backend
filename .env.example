# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# MongoDB
DB_CONNECTION=mongodb://localhost:27017/base-server

# PostgreSQL (for Aiven)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=base_server
POSTGRES_USERNAME=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_SSL=false

# AI Service API Keys
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GROK_API_KEY=your_grok_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# API Security (for external AI access)
API_SECRET=your_secret_key_here

# CORS Configuration
CORS_ORIGIN=*

# File Upload Configuration
MAX_FILE_SIZE=20000000
UPLOAD_BUCKET=uploads

# AI Research Assistant Configuration
TAVILY_API_KEY=your_tavily_api_key_here
ANALYST_MODEL=gemini-2.5-flash
FAST_MODEL=gemini-2.5-flash
MAX_REQUESTS_PER_IP=2
