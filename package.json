{
	"name": "base-server-template",
	"version": "2.0.0",
	"description": "Base server template with multi-DB support and AI integrations",
	"main": "server.js",
	"scripts": {
		"start": "node server.js",
		"dev": "NODE_ENV=development node server.js",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:manual:services": "node tests/manual/aiService.manual.test.js",
		"test:manual:routes": "node tests/manual/aiRoutes.manual.test.js"
	},
	"author": "Sanket",
	"license": "ISC",
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"@google/generative-ai": "^0.21.0",
		"@tavily/core": "^0.7.3",
		"axios": "^1.7.9",
		"config": "^3.3.12",
		"cors": "^2.8.5",
		"dotenv": "^16.5.0",
		"express": "^4.21.2",
		"mongoose": "^8.14.0",
		"multer": "^1.4.5-lts.1",
		"openai": "^4.73.1",
		"pg": "^8.13.1",
		"socket.io": "^4.8.3"
	},
	"devDependencies": {
		"jest": "^29.7.0",
		"nodemon": "^3.1.9",
		"supertest": "^6.3.4"
	},
	"imports": {
		"#models/*": "./models/*.js",
		"#services/*": "./src/services/*.js",
		"#database/*": "./src/database/*.js",
		"#config/*": "./config/*.js"
	}
}
